#------------------------------------------------------------------------------
# Common
#------------------------------------------------------------------------------
friendly_name_prefix  = "vaultkg"
location              = "centralus"
create_resource_group = true
resource_group_name   = "vault-kg"
vault_fqdn            = "vault.azure.karla-gabriel.sbx.hashidemos.io" # Must match TLS cert SAN entry
vault_version         = "1.21.4+ent"
#------------------------------------------------------------------------------
# Networking
#------------------------------------------------------------------------------
vnet_id                        = "/subscriptions/7a8f92c1-4ec1-4ac3-8c76-61f3e776f351/resourceGroups/vault-kg-rg/providers/Microsoft.Network/virtualNetworks/vaultkg-vnet"
vault_subnet_id                = "/subscriptions/7a8f92c1-4ec1-4ac3-8c76-61f3e776f351/resourceGroups/vault-kg-rg/providers/Microsoft.Network/virtualNetworks/vaultkg-vnet/subnets/vaultkg-vault-subnet"
lb_subnet_id                   = "/subscriptions/7a8f92c1-4ec1-4ac3-8c76-61f3e776f351/resourceGroups/vault-kg-rg/providers/Microsoft.Network/virtualNetworks/vaultkg-vnet/subnets/vaultkg-lb-subnet"
lb_is_internal                 = false
create_vault_public_dns_record = true
public_dns_zone_name           = "azure.karla-gabriel.sbx.hashidemos.io" # Must match vault_fqdn
public_dns_zone_rg             = "vault-kg-rg"                          # Resource Group containing the public DNS zone
#------------------------------------------------------------------------------
# Azure Key Vault installation secrets and unseal key
#------------------------------------------------------------------------------
prereqs_keyvault_rg_name               = "vault-kg-rg"
prereqs_keyvault_name                  = "vaultkg-preqs-kv"
vault_license_keyvault_secret_id       = "https://vaultkg-preqs-kv.vault.azure.net/secrets/vault-license/9e0ee0b82d0b48df84d577bea858b5f2"
vault_tls_cert_keyvault_secret_id      = "https://vaultkg-preqs-kv.vault.azure.net/secrets/vault-cert/619b7dac5c614fcba23960d9bdac5c22"
vault_tls_privkey_keyvault_secret_id   = "https://vaultkg-preqs-kv.vault.azure.net/secrets/vault-privkey/c07be29844cf4188b705aec92e702080"
vault_tls_ca_bundle_keyvault_secret_id = "https://vaultkg-preqs-kv.vault.azure.net/secrets/vault-ca-bundle/072eac14b62b4e6cac26506d0ad5710b"

vault_seal_azurekeyvault_vault_name      = "vaultkg-preqs-kv"
vault_seal_azurekeyvault_unseal_key_name = "vault-unseal-key-001"

#------------------------------------------------------------------------------
# Compute
#------------------------------------------------------------------------------
vm_ssh_public_key = "ssh-rsa  karla.gabriel@ibm.com"

vault_telemetry_config = {
  prometheus_retention_time = "30s"
  disable_hostname          = true
}

enable_telegraf_monitoring = true

